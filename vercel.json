{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/generate-pass.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "api/_lib/**"
    },
    "api/send-pass-email.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "api/_lib/**"
    }
  },
  "headers": [
    {
      "source": "/api/generate-pass",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
